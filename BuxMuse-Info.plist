<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.buxmuse.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>buxmuse</string>
			</array>
		</dict>
	</array>
	<key>NSFinancialDataUsageDescription</key>
	<string>BuxMuse reads transactions from Apple Wallet only when you turn on Wallet sync, to categorize spending and show balances in your ledger. Your financial data stays on your device and is not sold or shared.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
