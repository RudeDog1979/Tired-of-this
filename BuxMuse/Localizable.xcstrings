    "agreement.body.deposit" : {
      "extractionState" : "manual",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puede requerirse un depósito no reembolsable para reservar el trabajo o la fecha de inicio. El depósito se aplica a la factura final. Si el cliente cancela después de que el trabajo se haya programado o iniciado, el depósito puede retenerse para cubrir tiempo y costos perdidos."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
