    "agreement.body.force-majeure" : {
      "extractionState" : "manual",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ninguna parte incumple por retraso o falla causada por eventos fuera de su control razonable (p. ej., clima severo, enfermedad, escasez de suministros, acción gubernamental). Las fechas y costos afectados se renegociarán de buena fe."
          }
        },
        "es-419" : {
