    "agreement.body.retainer" : {
      "extractionState" : "manual",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando aplique un anticipo mensual o recurrente, se paga por adelantado y cubre las horas o servicios indicados en el alcance. El tiempo no usado del anticipo puede vencer al final del período salvo acuerdo distinto. El trabajo por encima del anticipo se cotiza o factura a la tarifa acordada."
          }
        },
        "es-419" : {
