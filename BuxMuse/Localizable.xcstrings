          }
        }
      }
    },
    "agreement.body.disputes" : {
      "extractionState" : "manual",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las partes intentarán resolver disputas de forma informal primero. Si eso falla, las disputas pueden derivarse a mediación o tribunales en la jurisdicción acordada por ambas partes (o donde el proveedor realice habitualmente su actividad si no se indica ninguna)."
          }
        },
        "es-419" : {
