          }
        }
      }
    },
    "BuxMuse never saves your password or recovery key on this device. You hold both — store them in a password manager, secure note, or offline copy." : {
      "extractionState" : "stale",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BuxMuse nunca guarda tu contraseña ni clave de recuperación en este dispositivo. Tú conservas ambas — guárdalas en un gestor de contraseñas, nota segura o copia física."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BuxMuse nunca guarda tu contraseña ni clave de recuperación en este dispositivo. Tú conservas ambas — guárdalas en un gestor de contraseñas, nota segura o copia física."
          }
        },
        "es-ES" : {
          "stringUnit" : {
