    "agreement.body.liability" : {
      "extractionState" : "manual",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En la máxima medida permitida por la ley, la responsabilidad total del proveedor por reclamos relacionados con este acuerdo se limita a los honorarios pagados por el cliente por el trabajo que originó el reclamo. Ninguna parte es responsable por pérdidas indirectas o consecuentes excepto donde la responsabilidad no pueda excluirse."
          }
        },
        "es-419" : {
