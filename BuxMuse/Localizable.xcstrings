          }
        }
      }
    },
    "agreement.body.cancellation-provider" : {
      "extractionState" : "manual",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El proveedor hará esfuerzos razonables para completar el trabajo según lo acordado. Si el proveedor debe cancelar, se notificará al cliente con prontitud y cualquier depósito o prepago por trabajo no realizado se reembolsará o reprogramará de común acuerdo."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El proveedor hará esfuerzos razonables para completar el trabajo según lo acordado. Si el proveedor debe cancelar, se notificará al cliente con prontitud y cualquier depósito o prepago por trabajo no realizado se reembolsará o reprogramará de común acuerdo."
          }
        },
        "es-ES" : {
