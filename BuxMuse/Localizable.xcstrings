    "agreement.body.gdpr" : {
      "extractionState" : "manual",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada parte procesará datos personales solo según sea necesario para cumplir este acuerdo y conforme a la ley de privacidad aplicable (incluido el RGPD del Reino Unido/UE cuando corresponda). Los datos de contacto y archivos del proyecto se usan para entrega, facturación y registros. El cliente no debe compartir datos personales de terceros sin base legal. Los datos pueden almacenarse en los dispositivos o herramientas del proveedor; el cliente puede solicitar acceso o corrección razonable de sus propios datos."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada parte procesará datos personales solo según sea necesario para cumplir este acuerdo y conforme a la ley de privacidad aplicable (incluido el RGPD del Reino Unido/UE cuando corresponda). Los datos de contacto y archivos del proyecto se usan para entrega, facturación y registros. El cliente no debe compartir datos personales de terceros sin base legal. Los datos pueden almacenarse en los dispositivos o herramientas del proveedor; el cliente puede solicitar acceso o corrección razonable de sus propios datos."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada parte procesará datos personales solo según sea necesario para cumplir este acuerdo y conforme a la ley de privacidad aplicable (incluido el RGPD del Reino Unido/UE cuando corresponda). Los datos de contacto y archivos del proyecto se usan para entrega, facturación y registros. El cliente no debe compartir datos personales de terceros sin base legal. Los datos pueden almacenarse en los dispositivos o herramientas del proveedor; el cliente puede solicitar acceso o corrección razonable de sus propios datos."
          }
        }
      }
    },
