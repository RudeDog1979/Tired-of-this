          }
        }
      }
    },
    "BuxMuse never sees your Health data on our servers — there are no BuxMuse servers for your finances or wellness. Sleep data stays on this iPhone." : {
      "extractionState" : "manual",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BuxMuse nunca ve tus datos de Salud en nuestros servidores — no hay servidores de BuxMuse para tus finanzas ni bienestar. Los datos de sueño permanecen en este iPhone."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
