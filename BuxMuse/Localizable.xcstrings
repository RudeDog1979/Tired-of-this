    "agreement.body.expenses" : {
      "extractionState" : "manual",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los materiales, viajes, estacionamiento, permisos y costos de terceros se facturan según lo acordado por adelantado o al costo más un margen acordado. Los costos inesperados se discutirán con el cliente antes de incurrir en ellos cuando sea práctico."
          }
        },
        "es-419" : {
