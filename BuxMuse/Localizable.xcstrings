    "Because BuxMuse is 100% offline with no servers, your ledger exists only on this device. We recommend setting up local notification alerts to remind you to back up your ledger." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Because BuxMuse is 100% offline with no servers, your ledger exists only on this device. We recommend setting up local notification alerts to remind you to back up your ledger."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dado que BuxMuse es 100% local y no tiene servidores, tu libro de contabilidad solo existe en este dispositivo. Te recomendamos configurar alertas de notificación locales para recordarte realizar copias de seguridad."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dado que BuxMuse es 100% local y no tiene servidores, tu libro de contabilidad solo existe en este dispositivo. Te recomendamos configurar alertas de notificación locales para recordarte realizar copias de seguridad."
          }
        },
        "es-ES" : {
