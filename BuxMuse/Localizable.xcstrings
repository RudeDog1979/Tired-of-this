    "agreement.body.cancellation-client" : {
      "extractionState" : "manual",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El cliente debe avisar con la mayor anticipación posible. Las cancelaciones con poca o ninguna anticipación después de confirmar una reserva pueden generar cargos por tiempo ya reservado, viaje o materiales pedidos. Cualquier depósito puede ser no reembolsable según lo indicado arriba."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El cliente debe avisar con la mayor anticipación posible. Las cancelaciones con poca o ninguna anticipación después de confirmar una reserva pueden generar cargos por tiempo ya reservado, viaje o materiales pedidos. Cualquier depósito puede ser no reembolsable según lo indicado arriba."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
